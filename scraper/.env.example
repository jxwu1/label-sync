# scraper 配置 (本地, 不进 git)
#
# 用法: cp .env.example .env 然后填值
# 脚本通过 python-dotenv 或手动 os.environ 读取

# Boson ERP 基础 URL (内网地址, 不进 repo)
BOSON_BASE_URL=http://bosonapp.local:8137

# Boson 登录凭据 (refresh_cookie.py 用, headless 自动登录拿 PHPSESSID)
BOSON_USERNAME=your_username
BOSON_PASSWORD=your_password
BOSON_ADD_CODE=your_add_code

# 抓取输出目录 (parquet + xlsx 落这里)
# 默认: scraper/staging/  (跟 .gitignore 对齐)
SCRAPE_OUTPUT_DIR=scraper/staging

# Cookie 文件路径 (PHPSESSID)
# 默认: scraper/cookie.txt  (跟 .gitignore 对齐)
SCRAPE_COOKIE_FILE=scraper/cookie.txt

# ============ 上传到服务器 (run_weekly.ps1 用) ============
# 服务器 upload endpoint, 跟 Coolify 上的域名一致
UPLOAD_URL=https://txfh1rjef5nr0r8zbsiq5csi.178.104.148.102.sslip.io/analytics/data/upload

# 服务器认证 token, 跟 Coolify env UPLOAD_TOKEN 一致
# 生成: ssh root@server "openssl rand -hex 32"
UPLOAD_TOKEN=paste-same-token-as-coolify
