{
  "permissions": {
    "allow": [
      "Bash(npx gitnexus *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/gitnexus-post-commit.cjs\""
          }
        ]
      }
    ]
  }
}
